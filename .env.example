# Used by docker-compose.yml to substitute ${CLOUDFLARE_TUNNEL_TOKEN}.
# Copy to .env (gitignored) and fill in.
#
# Create a tunnel at https://one.dash.cloudflare.com/ -> Networks -> Tunnels
# -> "Create a tunnel" -> "Cloudflared" -> copy the token shown in the
# install command (the long string after "tunnel run --token ").
#
# Then configure a Public Hostname for the tunnel in the dashboard:
#   https://<your-domain>/* -> http://frontend:3000
#
# Route everything to the frontend, NOT directly to backend:8000 — Next.js
# (next.config.mjs) already rewrites /api/* -> http://backend:8000/* and
# strips the /api prefix. The backend's own routes are not /api-prefixed,
# so a direct cloudflared route to backend for /api/* would 404.
CLOUDFLARE_TUNNEL_TOKEN=
