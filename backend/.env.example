# Required
ANTHROPIC_API_KEY=

# Auth — required to run the API / web app (`astromind serve`); the CLI commands work without it.
# JWT_SECRET signs the session cookie and must be >= 32 characters.
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=
JWT_EXPIRE_DAYS=7
# Set true in production (HTTPS) so the session cookie carries the Secure flag.
COOKIE_SECURE=false

# CORS — comma-separated list of allowed origins (defaults to localhost:3000)
# CORS_ORIGINS=http://localhost:3000,https://your-domain.com

# OAuth — Google and GitHub social login
# Google: https://console.cloud.google.com/apis/credentials
# GitHub: https://github.com/settings/developers
# Redirect URIs to register:
#   Google: {FRONTEND_URL}/api/auth/google/callback
#   GitHub: {FRONTEND_URL}/api/auth/github/callback
FRONTEND_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Admin bootstrap — the first admin account, created on startup / via `astromind seed-admin`.
# On first run, any pre-existing (anonymous-era) documents are backfilled to this admin.
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Optional overrides
# ANTHROPIC_MODEL: orchestrator agent (extended thinking). Sonnet or Opus recommended.
ANTHROPIC_MODEL=claude-sonnet-4-6
# ANTHROPIC_MODEL_LIGHT: sub-agents (chat, notebook synthesis). Haiku is fast and cheap.
ANTHROPIC_MODEL_LIGHT=claude-haiku-4-5-20251001
EMBED_MODEL=intfloat/multilingual-e5-small
# Galaxy morphology CNN model (.keras, ~40MB). Path is relative to the backend/
# working directory — the model file lives at the repo root by default, so use:
# GALAXY_MODEL_PATH=../galaxy_morphology_predictor/galaxy_morphology_predictor.keras
GALAXY_MODEL_PATH=galaxy_morphology_predictor/galaxy_morphology_predictor.keras
DATA_DIR=./data
LOG_LEVEL=INFO
# NASA APOD: defaults to the public DEMO_KEY; set for higher rate limits.
NASA_API_KEY=
# Tavily web-search (used by the `web` command and the assistant's web-search fallback).
TAVILY_API_KEY=
# SerpAPI (used by the `trends` report's Google Trends public-interest section).
SERPAPI_API_KEY=
# Estimated blended cost per 1,000 tokens, used for the admin cost KPI (USD)
COST_PER_1K_TOKENS=0.0007
